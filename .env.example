# ==============================================================================
# 🎯 HUNT3R EXCALIBUR - CONFIGURAÇÕES DE AMBIENTE
# ==============================================================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to git!
# ==============================================================================

# --- [ CREDENCIAIS PLATAFORMAS ] ---
HACKERONE_USERNAME=your_h1_username
HACKERONE_API_TOKEN=your_h1_api_token
H1_USER=your_h1_username
H1_TOKEN=your_h1_api_token
BC_TOKEN=bugcrowd_token_here
IT_TOKEN=intigriti_token_here

# --- [ CÉREBROS DE IA (CHAVES DE API) ] ---
OPENROUTER_API_KEY=sk-or-v1-xxxxx_your_key_here_xxxxx

# --- [ PATH PDTM] ---
HUNT3R_PDTM_PATH=/home/username/.pdtm/go/bin/

# --- [ IDENTIDADE E COMPLIANCE ] ---
# Usado nos Headers HTTP (User-Agent / X-Bug-Bounty) para evitar bans
MY_HACKER_HANDLE=@your_handle
MY_CONTACT_EMAIL=your_email@example.com

# --- [ NOTIFICAÇÕES TELEGRAM e DISCORD] ---
# Monitorização em tempo real
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DISCORD_WEBHOOK=https://discordapp.com/api/webhooks/your_webhook_url

# --- [ PERFORMANCE E PERSISTÊNCIA ] ---
DB_PATH=core/hunt3r_pro.db
DEFAULT_SCAN_PROFILE=standard

# --- PROJECTDISCOVERY CLOUD (CHAOS) ---
# Obtenha em: https://chaos.projectdiscovery.io/
CHAOS_KEY=your_chaos_api_key

# --- UNCOVER ENGINE (AGREGADORES) ---
# Shodan (Essencial para achar IPs e Portas abertas)
# Obtenha em: https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key

# --- CENSYS INTEGRATION ---
CENSYS_API_ID=your_censys_api_id
CENSYS_API_SECRET=your_censys_api_secret

# ==============================================================================
