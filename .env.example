# ==============================================================================
# 🎯 HUNT3R EXCALIBUR - CONFIGURAÇÕES DE AMBIENTE
# ==============================================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to git — it is in .gitignore.
# ==============================================================================

# --- [ CREDENCIAIS PLATAFORMAS ] ---
# HackerOne: https://hackerone.com/settings/api_token/edit
HACKERONE_USERNAME=your_h1_username
HACKERONE_API_TOKEN=your_h1_api_token
H1_USER=your_h1_username
H1_TOKEN=your_h1_api_token

# BugCrowd: https://bugcrowd.com/user/api_credentials
BC_TOKEN=your_bugcrowd_token

# Intigriti: https://app.intigriti.com/researcher/personal-access-tokens
IT_TOKEN=your_intigriti_token

# --- [ IA ] ---
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# --- [ PATH PDTM ] ---
# Caminho onde o PDTM instalou as ferramentas do ProjectDiscovery
HUNT3R_PDTM_PATH=/home/YOUR_USER/.pdtm/go/bin/

# --- [ IDENTIDADE E COMPLIANCE ] ---
# Usado nos Headers HTTP (User-Agent / X-Bug-Bounty) para evitar bans
MY_HACKER_HANDLE=@your_handle
MY_CONTACT_EMAIL=your_email@example.com

# --- [ NOTIFICAÇÕES ] ---
# Telegram: https://core.telegram.org/bots#botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Discord Webhook: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# --- [ PERFORMANCE E PERSISTÊNCIA ] ---
DB_PATH=core/hunt3r_pro.db
DEFAULT_SCAN_PROFILE=standard

# --- [ PROJECTDISCOVERY CLOUD ] ---
# Chaos: https://chaos.projectdiscovery.io/
CHAOS_KEY=your_chaos_api_key

# --- [ UNCOVER / SHODAN ] ---
# Shodan: https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key

# --- [ CENSYS ] ---
# Censys: https://search.censys.io/account/api
CENSYS_API_ID=your_censys_api_id
CENSYS_API_SECRET=your_censys_api_secret

# ==============================================================================
# FIM DO ARQUIVO — cp .env.example .env e preencha os valores reais
# ==============================================================================