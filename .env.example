# ==============================================================================
# 🎯 HUNT3R PRO - CONFIGURAÇÕES DE AMBIENTE (v1.0 STABLE)
# ==============================================================================

# --- [ CREDENCIAIS PLATAFORMAS ] ---
HACKERONE_USERNAME=
HACKERONE_API_TOKEN=
H1_USER=
H1_TOKEN=
BC_TOKEN=
IT_TOKEN=

# --- [ CÉREBROS DE IA (CHAVES DE API) ] ---
OPENROUTER_API_KEY=

# --- [ PATH PDTM] ---
HUNT3R_PDTM_PATH=/home/leonardofsp/.pdtm/go/bin/


# --- [ IDENTIDADE E COMPLIANCE ] ---
# Usado nos Headers HTTP (User-Agent / X-Bug-Bounty) para evitar bans
MY_HACKER_HANDLE=@svmpvix
MY_CONTACT_EMAIL=svmpvix@gmail.com

# --- [ NOTIFICAÇÕES TELEGRAM e DISCORD] ---
# Monitorização em tempo real
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK=

# --- [ PERFORMANCE E PERSISTÊNCIA ] ---
# DB_PATH: Onde o motor guarda os alvos minerados
# DEFAULT_SCAN_PROFILE: Define a agressividade inicial (standard/deep)
DB_PATH=core/hunt3r_pro.db
DEFAULT_SCAN_PROFILE=standard

# --- PROJECTDISCOVERY CLOUD (CHAOS) ---
# Obtenha em: https://chaos.projectdiscovery.io/
CHAOS_KEY=

# --- UNCOVER ENGINE (AGREGADORES) ---
# Shodan (Essencial para achar IPs e Portas abertas)
# Obtenha em: https://account.shodan.io/
SHODAN_API_KEY=

# ==============================================================================
# FIM DO ARQUIVO .env - MANTENHA EM SIGILO
# ==============================================================================